<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  iOS gates all local-network access (mDNS/Bonjour browse + advertise via
	  NWBrowser / NWListener) behind an explicit user permission. Without the
	  usage description the OS denies the browser with NWError -65555 (NoAuth)
	  and browsing silently restarts.
	-->
	<key>NSLocalNetworkUsageDescription</key>
	<string>Discover and connect to nearby iroh-http peers on your local network.</string>
	<!--
	  Every Bonjour service type the app browses or advertises must be declared
	  statically here, otherwise NWBrowser is denied even after permission is
	  granted. A serviceName maps to the DNS-SD type "_<serviceName>._<proto>".

	  - iroh peer discovery (advertisePeer/browsePeers) uses the default
	    serviceName "iroh-http" over UDP -> "_iroh-http._udp".
	  - the generic DNS-SD demo (node.advertise/node.browse) defaults to
	    serviceName "demo-printer" over TCP -> "_demo-printer._tcp".
	  - the opt-in interop test harness (#340 Test tab) advertises/browses
	    serviceName "iroh-http-test" over UDP -> "_iroh-http-test._udp".

	  Add an entry for each additional serviceName/protocol pair you use.
	-->
	<key>NSBonjourServices</key>
	<array>
		<string>_iroh-http._udp</string>
		<string>_demo-printer._tcp</string>
		<string>_iroh-http-test._udp</string>
	</array>
</dict>
</plist>
