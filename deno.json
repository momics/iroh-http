{
  "workspace": [
    "packages/iroh-http-shared",
    "packages/iroh-http-deno",
    "examples/deno",
    "tests/http-compliance"
  ],
  "nodeModulesDir": "none",
  "unstable": ["sloppy-imports"],
  "exclude": [
    "workspace/old_references",
    "target"
  ],
  "fmt": {
    "include": ["packages", "examples", "tests/http-compliance"],
    "exclude": [
      "**/node_modules",
      "**/dist",
      "**/*.svg",
      "**/*.css",
      "**/*.html",
      "**/*.xml",
      "tests/http-compliance/cases.json",
      "packages/iroh-http-node/index.js",
      "packages/iroh-http-node/index.d.ts",
      "packages/iroh-http-node/npm",
      "packages/iroh-http-tauri/permissions/autogenerated",
      "packages/iroh-http-tauri/permissions/schemas"
    ]
  },
  "test": {
    "include": [
      "packages/iroh-http-deno/test/adapter.test.ts"
    ]
  }
}
