  {
    "_comment": "=== REQUEST HEADERS (RFC 9110 §5) ==="
  },
  {
    "id": "header-custom-forwarded",
    "description": "Custom request header arrives at handler",
    "request": {
      "method": "GET",
      "path": "/header/x-test",
      "headers": { "x-test": "ping" },
      "body": null
    },
    "response": { "status": 200, "bodyExact": "ping" }
  },
  {
    "id": "header-multiple-custom",
    "description": "Multiple custom request headers all arrive",
    "request": {
      "method": "GET",
      "path": "/header/x-first",
      "headers": { "x-first": "alpha", "x-second": "beta" },
      "body": null
    },
    "response": { "status": 200, "bodyExact": "alpha" }
  },
  {
    "id": "header-case-insensitive",
    "description": "Header lookup is case-insensitive (RFC 9110 §5.1)",
    "request": {
      "method": "GET",
      "path": "/header/x-mixed-case",
      "headers": { "X-Mixed-Case": "case-test" },
      "body": null
    },
    "response": { "status": 200, "bodyExact": "case-test" }
  },
  {
    "id": "header-empty-value",
    "description": "Header with empty string value is forwarded",
    "skip": "Rust HTTP layer rejects empty header values",
    "request": {
      "method": "GET",
      "path": "/header-exists/x-empty",
      "headers": { "x-empty": "" },
      "body": null
    },
    "response": { "status": 200, "bodyExact": "true" }
  },
  {
    "id": "header-long-value",
    "description": "Header with long value (8 KiB) is forwarded",
    "skip": "fill syntax for header values not implemented in simple runners",
    "request": {
      "method": "GET",
      "path": "/header-length/x-long",
      "headers": { "x-long": { "fill": 8192 } },
      "body": null
    },
    "response": { "status": 200, "bodyExact": "8192" }
  },
  {
    "id": "header-content-type-forwarded",
    "description": "Content-Type header arrives at handler",
    "request": {
      "method": "POST",
      "path": "/header/content-type",
      "headers": { "content-type": "application/json" },
      "body": "{}"
    },
    "response": { "status": 200, "bodyExact": "application/json" }
  },
  {
    "id": "header-accept-forwarded",
    "description": "Accept header arrives at handler",
    "request": {
      "method": "GET",
      "path": "/header/accept",
      "headers": { "accept": "text/html, application/json" },
      "body": null
    },
    "response": { "status": 200, "bodyExact": "text/html, application/json" }
  },
  {
    "id": "header-user-agent-forwarded",
    "description": "User-Agent header arrives at handler",
    "request": {
      "method": "GET",
      "path": "/header/user-agent",
      "headers": { "user-agent": "iroh-test/1.0" },
      "body": null
    },
    "response": { "status": 200, "bodyExact": "iroh-test/1.0" }
  },
  {
    "id": "header-authorization-forwarded",
    "description": "Authorization header arrives at handler",
    "request": {
      "method": "GET",
      "path": "/header/authorization",
      "headers": { "authorization": "Bearer tok_test123" },
      "body": null
    },
    "response": { "status": 200, "bodyExact": "Bearer tok_test123" }
  },

  {
    "_comment": "=== RESPONSE HEADERS ==="
  },
  {
    "id": "response-header-single",
    "description": "Handler can set a custom response header",
    "request": { "method": "GET", "path": "/set-header/x-reply/pong", "headers": {}, "body": null },
    "response": { "status": 200, "headers": { "x-reply": "pong" } }
  },
  {
    "id": "response-header-multiple",
    "description": "Multiple custom response headers are all delivered",
    "request": { "method": "GET", "path": "/set-headers/3", "headers": {}, "body": null },
    "response": { "status": 200, "headers": { "x-h-0": "v0", "x-h-1": "v1", "x-h-2": "v2" } }
  },
  {
    "id": "response-header-5",
    "description": "5 custom response headers are all delivered",
    "request": { "method": "GET", "path": "/set-headers/5", "headers": {}, "body": null },
    "response": { "status": 200, "headers": { "x-h-0": "v0", "x-h-1": "v1", "x-h-2": "v2", "x-h-3": "v3", "x-h-4": "v4" } }
  },
  {
    "id": "response-header-content-type",
    "description": "Content-Type response header is forwarded to client",
    "request": { "method": "GET", "path": "/typed-json", "headers": {}, "body": null },
    "response": { "status": 200, "headers": { "content-type": "application/json" }, "bodyExact": "{\"ok\":true}" }
  },
  {
    "id": "response-header-content-type-html",
    "description": "text/html Content-Type is forwarded",
    "request": { "method": "GET", "path": "/typed-html", "headers": {}, "body": null },
    "response": { "status": 200, "headers": { "content-type": "text/html" }, "bodyExact": "<h1>hello</h1>" }
  },

  {
    "_comment": "=== PEER-ID SECURITY ==="
  },
  {
    "id": "peer-id-present",
    "description": "Peer-Id header is injected and non-empty",
    "request": { "method": "GET", "path": "/header/peer-id", "headers": {}, "body": null },
    "response": { "status": 200, "bodyNotEmpty": true }
  },
  {
    "id": "peer-id-not-spoofable",
    "description": "Client-supplied Peer-Id is stripped; reflects real peer identity",
    "request": {
      "method": "GET",
      "path": "/header/peer-id",
      "headers": { "peer-id": "SPOOFED" },
      "body": null
    },
    "response": { "status": 200, "bodyNot": "SPOOFED" }
  },
  {
    "id": "peer-id-consistent",
    "description": "Peer-Id is the same across multiple requests from same client",
    "tags": ["concurrent"],
    "request": { "method": "GET", "path": "/header/peer-id", "headers": {}, "body": null },
    "response": { "status": 200, "bodyNotEmpty": true },
    "repeat": 3,
    "assertAllBodiesEqual": true
  },
  {
    "id": "peer-id-format",
    "description": "Peer-Id looks like a valid public key (base32-lower, 52 chars)",
    "request": { "method": "GET", "path": "/header/peer-id", "headers": {}, "body": null },
    "response": { "status": 200, "bodyMatchesRegex": "^[a-z2-7]{52}$" }
  },

  {
    "_comment": "=== PATH HANDLING (RFC 9110 §7.1) ==="
  },
  {
    "id": "path-root",
    "description": "Root path / is preserved",
    "request": { "method": "GET", "path": "/echo-path", "headers": {}, "body": null },
    "response": { "status": 200, "bodyExact": "/echo-path" }
  },
  {
    "id": "path-trailing-slash",
    "description": "Trailing slash is preserved",
    "request": { "method": "GET", "path": "/echo-path/", "headers": {}, "body": null },
    "response": { "status": 200, "bodyExact": "/echo-path/" }
  },
  {
    "id": "path-deeply-nested",
    "description": "Deeply-nested path segments are preserved",
    "request": { "method": "GET", "path": "/echo-path/a/b/c/d/e", "headers": {}, "body": null },
    "response": { "status": 200, "bodyExact": "/echo-path/a/b/c/d/e" }
  },
  {
    "id": "path-query-string",
    "description": "Query string is preserved",
    "request": { "method": "GET", "path": "/echo-query?foo=bar&baz=1", "headers": {}, "body": null },
    "response": { "status": 200, "bodyExact": "?foo=bar&baz=1" }
  },
  {
    "id": "path-query-multiple-params",
    "description": "Query string with multiple parameters is forwarded verbatim",
    "request": { "method": "GET", "path": "/echo-query?a=1&b=2&c=hello", "headers": {}, "body": null },
    "response": { "status": 200, "bodyExact": "?a=1&b=2&c=hello" }
  },
  {
    "id": "path-query-empty-value",
    "description": "Query parameter with empty value is preserved",
    "request": { "method": "GET", "path": "/echo-query?key=&other=val", "headers": {}, "body": null },
    "response": { "status": 200, "bodyExact": "?key=&other=val" }
  },
  {
    "id": "path-query-no-value",
    "description": "Query parameter with no value is preserved",
    "request": { "method": "GET", "path": "/echo-query?flag&other=val", "headers": {}, "body": null },
    "response": { "status": 200, "bodyExact": "?flag&other=val" }
  },
  {
    "id": "path-url-encoded",
    "description": "URL-encoded path segments are preserved verbatim",
    "request": { "method": "GET", "path": "/echo-path/hello%20world", "headers": {}, "body": null },
    "response": { "status": 200, "bodyContains": "hello%20world" }
  },
  {
    "id": "path-url-encoded-slash",
    "description": "URL-encoded slash (%2F) in path is preserved",
    "request": { "method": "GET", "path": "/echo-path/a%2Fb", "headers": {}, "body": null },
    "response": { "status": 200, "bodyContains": "%2F" }
  },
  {
    "id": "path-special-chars-query",
    "description": "Special characters in query string are preserved",
    "request": { "method": "GET", "path": "/echo-query?msg=hello+world&tag=%23iroh", "headers": {}, "body": null },
    "response": { "status": 200, "bodyExact": "?msg=hello+world&tag=%23iroh" }
  },
  {
    "id": "path-unicode-query",
    "description": "Unicode in query string is preserved",
    "request": { "method": "GET", "path": "/echo-query?name=%E4%B8%96%E7%95%8C", "headers": {}, "body": null },
    "response": { "status": 200, "bodyExact": "?name=%E4%B8%96%E7%95%8C" }
  },
  {
    "id": "path-dot-segments",
    "description": "Dot segments in path are preserved (not resolved)",
    "skip": "URL parser resolves dot segments before dispatch",
    "request": { "method": "GET", "path": "/echo-path/a/../b", "headers": {}, "body": null },
    "response": { "status": 200, "bodyContains": "/a/../b" }
  },

  {
    "_comment": "=== CONCURRENT REQUESTS ==="
  },
  {
    "id": "concurrent-3-gets",
    "description": "3 concurrent GET requests all succeed",
    "concurrent": 3,
    "request": { "method": "GET", "path": "/status/200", "headers": {}, "body": null },
    "response": { "status": 200 }
  },
  {
    "id": "concurrent-5-posts",
    "description": "5 concurrent POST requests with body all echo correctly",
    "concurrent": 5,
    "request": { "method": "POST", "path": "/echo-method", "headers": {}, "body": null },
    "response": { "status": 200, "bodyExact": "POST" }
  },
  {
    "id": "concurrent-10-mixed",
    "description": "10 concurrent requests all succeed",
    "concurrent": 10,
    "request": { "method": "GET", "path": "/status/200", "headers": {}, "body": null },
    "response": { "status": 200 }
  },
  {
    "id": "concurrent-with-body",
    "description": "3 concurrent POSTs with different bodies (all echo same method)",
    "concurrent": 3,
    "request": { "method": "POST", "path": "/echo", "headers": {}, "body": "concurrent-body" },
    "response": { "status": 200, "bodyExact": "concurrent-body" }
  },

  {
    "_comment": "=== SEQUENTIAL REQUESTS (connection reuse) ==="
  },
  {
    "id": "sequential-10-requests",
    "description": "10 sequential requests on the same node all succeed",
    "sequential": 10,
    "request": { "method": "GET", "path": "/echo-method", "headers": {}, "body": null },
    "response": { "status": 200, "bodyExact": "GET" }
  },
  {
    "id": "sequential-mixed-methods",
    "description": "Sequential requests with different methods all succeed",
    "requests": [
      { "method": "GET", "path": "/echo-method", "headers": {}, "body": null, "expect": { "status": 200, "bodyExact": "GET" } },
      { "method": "POST", "path": "/echo-method", "headers": {}, "body": null, "expect": { "status": 200, "bodyExact": "POST" } },
      { "method": "PUT", "path": "/echo-method", "headers": {}, "body": null, "expect": { "status": 200, "bodyExact": "PUT" } },
      { "method": "DELETE", "path": "/echo-method", "headers": {}, "body": null, "expect": { "status": 200, "bodyExact": "DELETE" } }
    ]
  },
  {
    "id": "sequential-mixed-status",
    "description": "Sequential requests returning different status codes",
    "requests": [
      { "method": "GET", "path": "/status/200", "headers": {}, "body": null, "expect": { "status": 200 } },
      { "method": "GET", "path": "/status/404", "headers": {}, "body": null, "expect": { "status": 404 } },
      { "method": "GET", "path": "/status/500", "headers": {}, "body": null, "expect": { "status": 500 } },
      { "method": "GET", "path": "/status/200", "headers": {}, "body": null, "expect": { "status": 200 } }
    ]
  },

  {
    "_comment": "=== CONTENT-TYPE HANDLING ==="
  },
  {
    "id": "content-type-json-response",
    "description": "Server sets application/json and client receives it",
    "request": { "method": "GET", "path": "/typed-json", "headers": {}, "body": null },
    "response": { "status": 200, "headers": { "content-type": "application/json" } }
  },
  {
    "id": "content-type-plain-response",
    "description": "Server sets text/plain and client receives it",
    "request": { "method": "GET", "path": "/typed-text", "headers": {}, "body": null },
    "response": { "status": 200, "headers": { "content-type": "text/plain" } }
  },
  {
    "id": "content-type-octet-stream",
    "description": "Server sets application/octet-stream and client receives it",
    "request": { "method": "GET", "path": "/typed-binary", "headers": {}, "body": null },
    "response": { "status": 200, "headers": { "content-type": "application/octet-stream" } }
  },
  {
    "id": "content-type-with-charset",
    "description": "Content-Type with charset parameter is forwarded",
    "request": { "method": "GET", "path": "/typed-utf8", "headers": {}, "body": null },
    "response": { "status": 200, "headers": { "content-type": "text/plain; charset=utf-8" } }
  },

  {
    "_comment": "=== EDGE CASES ==="
  },
  {
    "id": "edge-empty-body-with-content-type",
    "description": "POST with Content-Type but empty body",
    "request": {
      "method": "POST",
      "path": "/echo-length",
      "headers": { "content-type": "application/json" },
      "body": null
    },
    "response": { "status": 200, "bodyExact": "0" }
  },
  {
    "id": "edge-response-with-custom-status-text",
    "description": "Unusual but valid status code 299 is forwarded",
    "request": { "method": "GET", "path": "/status/299", "headers": {}, "body": null },
    "response": { "status": 299 }
  },
  {
    "id": "edge-very-long-path",
    "description": "Path with 200 segments is preserved",
    "request": {
      "method": "GET",
      "path": "/echo-path/a/b/c/d/e/f/g/h/i/j/k/l/m/n/o/p/q/r/s/t/u/v/w/x/y/z/a/b/c/d/e/f/g/h/i/j/k/l/m/n/o/p/q/r/s/t/u/v/w/x",
      "headers": {},
      "body": null
    },
    "response": { "status": 200, "bodyNotEmpty": true }
  },
  {
    "id": "edge-many-headers",
    "description": "Request with 20 custom headers — all arrive",
    "request": {
      "method": "GET",
      "path": "/header-count",
      "headers": {
        "x-h-01": "1", "x-h-02": "2", "x-h-03": "3", "x-h-04": "4", "x-h-05": "5",
        "x-h-06": "6", "x-h-07": "7", "x-h-08": "8", "x-h-09": "9", "x-h-10": "10",
        "x-h-11": "11", "x-h-12": "12", "x-h-13": "13", "x-h-14": "14", "x-h-15": "15",
        "x-h-16": "16", "x-h-17": "17", "x-h-18": "18", "x-h-19": "19", "x-h-20": "20"
      },
      "body": null
    },
    "response": { "status": 200, "bodyMinLength": 2 }
  },
  {
    "id": "edge-response-body-after-status-error",
    "description": "Error status code with body — body is forwarded",
    "request": { "method": "GET", "path": "/error-with-body", "headers": {}, "body": null },
    "response": { "status": 500, "bodyExact": "something went wrong" }
  },
  {
    "id": "edge-whitespace-body",
    "description": "Body consisting only of whitespace round-trips",
    "request": { "method": "POST", "path": "/echo", "headers": {}, "body": "   \n\t  " },
    "response": { "status": 200, "bodyExact": "   \n\t  " }
  },
  {
    "id": "edge-single-char-body",
    "description": "Single character body round-trips",
    "request": { "method": "POST", "path": "/echo", "headers": {}, "body": "x" },
    "response": { "status": 200, "bodyExact": "x" }
  }
]
