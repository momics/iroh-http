  {
    "_comment": "=== HTTP METHODS (RFC 9110 §9) ==="
  },
  {
    "id": "method-get",
    "description": "GET method reaches handler",
    "request": { "method": "GET", "path": "/echo-method", "headers": {}, "body": null },
    "response": { "status": 200, "bodyExact": "GET" }
  },
  {
    "id": "method-post",
    "description": "POST method reaches handler",
    "request": { "method": "POST", "path": "/echo-method", "headers": {}, "body": null },
    "response": { "status": 200, "bodyExact": "POST" }
  },
  {
    "id": "method-put",
    "description": "PUT method reaches handler",
    "request": { "method": "PUT", "path": "/echo-method", "headers": {}, "body": null },
    "response": { "status": 200, "bodyExact": "PUT" }
  },
  {
    "id": "method-patch",
    "description": "PATCH method reaches handler",
    "request": { "method": "PATCH", "path": "/echo-method", "headers": {}, "body": null },
    "response": { "status": 200, "bodyExact": "PATCH" }
  },
  {
    "id": "method-delete",
    "description": "DELETE method reaches handler",
    "request": { "method": "DELETE", "path": "/echo-method", "headers": {}, "body": null },
    "response": { "status": 200, "bodyExact": "DELETE" }
  },
  {
    "id": "method-options",
    "description": "OPTIONS method reaches handler",
    "request": { "method": "OPTIONS", "path": "/echo-method", "headers": {}, "body": null },
    "response": { "status": 200, "bodyExact": "OPTIONS" }
  },
  {
    "id": "method-head",
    "description": "HEAD returns status but no body (RFC 9110 §9.3.2)",
    "request": { "method": "HEAD", "path": "/status/200", "headers": {}, "body": null },
    "response": { "status": 200 }
  },
  {
    "id": "method-custom-verb",
    "description": "Custom HTTP verb (SEARCH) reaches handler",
    "request": { "method": "SEARCH", "path": "/echo-method", "headers": {}, "body": null },
    "response": { "status": 200, "bodyExact": "SEARCH" }
  },
  {
    "id": "method-custom-verb-2",
    "description": "Another custom verb (PURGE) reaches handler",
    "request": { "method": "PURGE", "path": "/echo-method", "headers": {}, "body": null },
    "response": { "status": 200, "bodyExact": "PURGE" }
  },

  {
    "_comment": "=== BODY HANDLING (RFC 9110 §6.4) ==="
  },
  {
    "id": "body-echo-post",
    "description": "POST body is echoed back",
    "request": { "method": "POST", "path": "/echo", "headers": {}, "body": "hello iroh" },
    "response": { "status": 200, "bodyExact": "hello iroh" }
  },
  {
    "id": "body-echo-put",
    "description": "PUT body is echoed back",
    "request": { "method": "PUT", "path": "/echo", "headers": {}, "body": "put payload" },
    "response": { "status": 200, "bodyExact": "put payload" }
  },
  {
    "id": "body-echo-patch",
    "description": "PATCH body is echoed back",
    "request": { "method": "PATCH", "path": "/echo", "headers": {}, "body": "patch payload" },
    "response": { "status": 200, "bodyExact": "patch payload" }
  },
  {
    "id": "body-echo-delete",
    "description": "DELETE body is echoed back (RFC allows it)",
    "request": { "method": "DELETE", "path": "/echo", "headers": {}, "body": "delete payload" },
    "response": { "status": 200, "bodyExact": "delete payload" }
  },
  {
    "id": "body-echo-options",
    "description": "OPTIONS body is forwarded to handler",
    "request": { "method": "OPTIONS", "path": "/echo", "headers": {}, "body": "options body" },
    "response": { "status": 200, "bodyExact": "options body" }
  },
  {
    "id": "body-echo-custom-verb",
    "description": "Custom verb body is forwarded to handler",
    "request": { "method": "SEARCH", "path": "/echo", "headers": {}, "body": "custom verb body" },
    "response": { "status": 200, "bodyExact": "custom verb body" }
  },
  {
    "id": "body-empty-post",
    "description": "POST with null body results in 0-byte body",
    "request": { "method": "POST", "path": "/echo-length", "headers": {}, "body": null },
    "response": { "status": 200, "bodyExact": "0" }
  },
  {
    "id": "body-empty-response",
    "description": "Zero-byte response body is handled correctly",
    "request": { "method": "GET", "path": "/stream/0", "headers": {}, "body": null },
    "response": { "status": 200, "bodyLengthExact": 0 }
  },
  {
    "id": "response-body-static-hello",
    "description": "Static (non-echo) response body round-trips (#338 Android empty-body regression)",
    "request": { "method": "GET", "path": "/hello", "headers": {}, "body": null },
    "response": { "status": 200, "bodyExact": "hello" }
  },
  {
    "id": "body-utf8",
    "description": "UTF-8 multibyte body round-trips correctly",
    "request": {
      "method": "POST",
      "path": "/echo",
      "headers": { "content-type": "text/plain; charset=utf-8" },
      "body": "こんにちは世界"
    },
    "response": { "status": 200, "bodyExact": "こんにちは世界" }
  },
  {
    "id": "body-utf8-emoji",
    "description": "Emoji in body round-trips correctly (4-byte UTF-8)",
    "request": {
      "method": "POST",
      "path": "/echo",
      "headers": { "content-type": "text/plain; charset=utf-8" },
      "body": "Hello 🌍🚀💫"
    },
    "response": { "status": 200, "bodyExact": "Hello 🌍🚀💫" }
  },
  {
    "id": "body-utf8-mixed",
    "description": "Mixed script body round-trips correctly",
    "request": {
      "method": "POST",
      "path": "/echo",
      "headers": {},
      "body": "Hello مرحبا שלום Привет 你好"
    },
    "response": { "status": 200, "bodyExact": "Hello مرحبا שלום Привет 你好" }
  },
  {
    "id": "body-json-roundtrip",
    "description": "JSON body round-trips correctly",
    "request": {
      "method": "POST",
      "path": "/echo",
      "headers": { "content-type": "application/json" },
      "body": "{\"key\":\"value\",\"num\":42,\"arr\":[1,2,3]}"
    },
    "response": { "status": 200, "bodyExact": "{\"key\":\"value\",\"num\":42,\"arr\":[1,2,3]}" }
  },
  {
    "id": "body-newlines",
    "description": "Body with various newline types round-trips correctly",
    "request": {
      "method": "POST",
      "path": "/echo",
      "headers": {},
      "body": "line1\nline2\r\nline3\rline4"
    },
    "response": { "status": 200, "bodyExact": "line1\nline2\r\nline3\rline4" }
  },
  {
    "id": "body-special-chars",
    "description": "Body with special characters round-trips correctly",
    "request": {
      "method": "POST",
      "path": "/echo",
      "headers": {},
      "body": "<script>alert('xss')</script>&foo=bar\"quotes\""
    },
    "response": { "status": 200, "bodyExact": "<script>alert('xss')</script>&foo=bar\"quotes\"" }
  },

