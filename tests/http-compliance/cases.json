[
  {
    "_comment": "=== STATUS CODES (RFC 9110 §15) ===",
    "_comment2": "Comprehensive coverage across all status-code classes"
  },
  {
    "id": "status-200",
    "description": "GET returns 200 OK",
    "request": { "method": "GET", "path": "/status/200", "headers": {}, "body": null },
    "response": { "status": 200 }
  },
  {
    "id": "status-201",
    "description": "POST returns 201 Created",
    "request": { "method": "POST", "path": "/status/201", "headers": {}, "body": null },
    "response": { "status": 201 }
  },
  {
    "id": "status-202",
