{
  "name": "@momics/iroh-http-node",
  "version": "0.6.0",
  "description": "Node.js native addon for iroh-http (napi-rs)",
  "main": "./lib.js",
  "types": "./lib.d.ts",
  "napi": {
    "binaryName": "iroh-http-node",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "build": "napi build --platform --release && tsc",
    "build:debug": "napi build --platform && tsc",
    "build:all": "node scripts/build-all.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node --test test/adapter.test.mjs test/utils.test.mjs && node test/compliance.mjs",
    "test:adapter": "node --test test/adapter.test.mjs",
    "test:utils": "node --test test/utils.test.mjs",
    "test:compliance": "node test/compliance.mjs"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.7.3",
    "@types/node": "^26.1.0",
    "typescript": "^5"
  },
  "dependencies": {
    "@momics/iroh-http-shared": "^0.6"
  },
  "optionalDependencies": {
    "@momics/iroh-http-node-darwin-arm64": "0.6.0",
    "@momics/iroh-http-node-darwin-x64": "0.6.0",
    "@momics/iroh-http-node-linux-arm64-gnu": "0.6.0",
    "@momics/iroh-http-node-linux-x64-gnu": "0.6.0",
    "@momics/iroh-http-node-win32-x64-msvc": "0.6.0"
  },
  "files": [
    "*.js",
    "*.d.ts"
  ],
  "publishConfig": {
    "access": "public"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "license": "(MIT OR Apache-2.0)",
  "repository": {
    "type": "git",
    "url": "https://github.com/momics/iroh-http"
  },
  "homepage": "https://github.com/momics/iroh-http"
}
