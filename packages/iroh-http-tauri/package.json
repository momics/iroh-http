{
  "name": "@momics/iroh-http-tauri",
  "version": "0.5.0",
  "description": "Tauri plugin for iroh-http peer-to-peer HTTP",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "cargo check && tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@tauri-apps/api": "^2"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2",
    "jsdom": "^29.1.0",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@momics/iroh-http-shared": "^0.5"
  },
  "files": [
    "dist",
    "guest-js"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "(MIT OR Apache-2.0)",
  "repository": {
    "type": "git",
    "url": "https://github.com/Momics/iroh-http"
  },
  "homepage": "https://github.com/Momics/iroh-http"
}
