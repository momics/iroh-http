<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Required by the `get_dns_servers` command so the plugin can read the
         active network's DNS servers (ConnectivityManager / LinkProperties) and
         configure iroh's resolver on Android, where the system DNS config is
         otherwise unreadable. Merged into every consumer app's manifest. -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
</manifest>
