{
  "name": "@momics/iroh-http-shared",
  "version": "0.6.0",
  "description": "Shared TypeScript layer for iroh-http — no native dependencies",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./adapter": {
      "import": "./dist/adapter.js",
      "require": "./dist/adapter.js",
      "types": "./dist/adapter.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "prepare": "tsc --project tsconfig.json",
    "test": "deno test test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^7.0.2"
  },
  "files": ["dist", "src"],
  "publishConfig": { "access": "public" },
  "license": "(MIT OR Apache-2.0)",
  "repository": {
    "type": "git",
    "url": "https://github.com/momics/iroh-http"
  },
  "homepage": "https://github.com/momics/iroh-http"
}
