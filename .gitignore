# Rust
target/

# Node
node_modules/

# TypeScript build output
# iroh-http-shared/dist is generated by `prepare` — not committed.
dist/
*.tsbuildinfo

# napi-rs generated files (iroh-http-node)
# index.js and index.d.ts are committed so CI can always find them even when
# the Rust build is fully cached (proc-macros don't re-run on cache hits).
*.node
packages/iroh-http-node/lib.js
packages/iroh-http-node/lib.d.ts
packages/iroh-http-node/*.map

# Deno compiled libraries
packages/iroh-http-deno/lib/*.dylib
packages/iroh-http-deno/lib/*.so
packages/iroh-http-deno/lib/*.dll

# Python
__pycache__/
*.egg-info/
*.whl
*.so
.venv/

# macOS
.DS_Store
Thumbs.db

# Editor
*.swp
*.swo

# Local folders
workspace/old_references
.obsidian
temp/
.agents
skills-lock.json

# Environment & secrets (defense-in-depth — none should exist, but block accidental commits)
.env
.env.*
*.env
.npmrc
.netrc
credentials
credentials.json
*_credentials*
service-account*.json
serviceaccount*.json
*oauth*token*
token.json
*.pem
*.p12
*.pfx
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
id_ecdsa
id_ecdsa.pub

# Benchmark outputs (uploaded as CI artifacts)
bench/results/*
!bench/results/.gitkeep

# Interop result collector (local device-test artifacts + persisted identity)
tests/interop/reporter/reports/*
!tests/interop/reporter/reports/.gitkeep
tests/interop/reporter/.identity.b32
